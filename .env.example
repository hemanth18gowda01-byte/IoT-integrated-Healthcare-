# VitalSync Environment Configuration
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://vitalsync:your_password@localhost:3306/vitalsync

# ── Security ──────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Fernet encryption key for sensitive medical data
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ── AI / LLM ──────────────────────────────────────────────
GEMINI_API_KEY=sk-ant-your-key-here

# ── MQTT Broker ───────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=vitalsync
MQTT_PASSWORD=mqtt_password

# ── App Config ────────────────────────────────────────────
APP_NAME=VitalSync
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000

# Emergency alert check interval (seconds)
VITAL_CHECK_INTERVAL=300

# Daily check-in time (24h format)
DAILY_CHECKIN_HOUR=20
